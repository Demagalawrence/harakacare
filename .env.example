# HarakaCare Environment Variables
# Copy this file to .env and fill in your actual values

# Facility API Configuration
FACILITY_API_KEY=your_actual_api_key_here
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/harakacare_db

# Django Settings
SECRET_KEY=your_django_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1

# External Services
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Meta WhatsApp Cloud API Credentials
# Get these from your Meta Developer Dashboard

# 1. Access Token (from WhatsApp → Settings → Generate Token)
META_WHATSAPP_ACCESS_TOKEN=your_access_token_here

# 2. Phone Number ID (from WhatsApp → Phone Numbers)
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# 3. Webhook Verify Token (your choice - must match Meta dashboard)
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=harakacare_verify123

# 4. App Secret (from App → Settings → Basic → Show App Secret)
META_WHATSAPP_APP_SECRET=your_app_secret_here

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_password
